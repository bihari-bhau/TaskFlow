# ─────────────────────────────────────────────────────────────────────────────
# TaskFlow Backend — Environment Variables
# Copy this to .env for local development.
# On Railway, set these in: Service → Variables tab.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Local (SQLite, no Postgres needed):
DATABASE_URL=sqlite:///./taskflow.db

# Local (docker-compose Postgres):
# DATABASE_URL=postgresql://taskflow:taskflow_secret@db:5432/taskflow

# Railway Postgres (Production) — paste the URI from:
#   Railway Dashboard → Service → Variables → DATABASE_URL
# It typically looks like:
#   postgresql://postgres:[password]@containers-<id>.railway.app:5432/railway
# You can set either `DATABASE_URL` or `RAILWAY_DATABASE_URL` in Railway.
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@containers-XXXX.railway.app:5432/railway

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=taskflow-dev-secret-CHANGE-THIS-IN-PRODUCTION

# ── CORS ──────────────────────────────────────────────────────────────────────
# Local dev: leave as * (allow all origins)
ALLOWED_ORIGINS=*

# Production on Railway: set to your exact frontend Railway URL
# ALLOWED_ORIGINS=https://taskflow-frontend.up.railway.app

# ── Seeding (docker-compose only) ─────────────────────────────────────────────
# Set to "true" to auto-populate demo data on first startup
SEED_DB=false
