# frontend/.env.production
#
# This file is used when building the React app for production.
# Replace the placeholder URL with your actual Railway backend URL.
#
# ⚠️  On Railway, set REACT_APP_API_URL as an environment variable
#     in the frontend service BEFORE triggering a deploy — React
#     bakes this value into the compiled JS bundle at build time.
#
# Format: https://<your-backend-service-name>.up.railway.app/api

REACT_APP_API_URL=https://taskflow-backend.up.railway.app/api
